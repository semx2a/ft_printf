# **************************************************************************** #
#                                TARGET                                        #
# **************************************************************************** #

NAME	= libftprintf.a

# **************************************************************************** #
#                            SOURCES && OBJS                                   #
# **************************************************************************** #

SRCS	= ft_printf.c ft_numbers.c ft_strings.c 

OBJS	= ${SRCS:%.c=%.o}

# **************************************************************************** #
#                                COMPILERS                                     #
# **************************************************************************** #

CC		= gcc

CFLAGS	= -Wall -Wextra -Werror -c

AR		= ar

ARFLAGS	= rcs

# **************************************************************************** #
#                                 HEADERS                                      #
# **************************************************************************** #

INC		= ft_printf.h

# **************************************************************************** #
#                                  MISC                                        #
# **************************************************************************** #

RM		= rm -f

# **************************************************************************** #
#                                SCRIPTS                                       #
# **************************************************************************** #

$(NAME):	${OBJS}
	${AR} ${ARFLAGS} ${NAME} ${OBJS} 

$(OBJS):	${SRCS}
	${CC} -I $(INC) ${CFLAGS} ${SRCS}

# **************************************************************************** #
#                                 RULES                                        #
# **************************************************************************** #

all:		${NAME}

clean:
	${RM} ${OBJS}

fclean:	clean
	${RM} ${NAME}

re:		fclean all

.PHONY:	all clean fclean re
